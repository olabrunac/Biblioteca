    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug current folder (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/app.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb.exe",
            "setupCommands": [
                {
                    "description": "Habilitar pretty-printing no gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: build active folder"
        }
    ]
}