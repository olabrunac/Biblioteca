{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "build_g++",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "*.cpp",
                "-o",
                "${fileBasenameNoExtension}"
            ],
            "windows": {
                "command": "g++.exe",
                "args": [
                    "-fdiagnostics-color=always",
                    "-g",
                    "*.cpp",
                    "-o",
                    "${fileBasenameNoExtension}.exe"
                ]
            },
        // Dica: Para instalar o g++ e o depurador no Ubuntu, use o comando no terminal:
        // sudo apt update && sudo apt install build-essential gdb
            "linux": {
                "command": "/usr/bin/g++"
            },
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Tarefa gerada para compilar todos os arquivos .cpp da pasta atual."
        }
    ]
}
