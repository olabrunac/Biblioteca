{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: build Entrega 1",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "main.cpp",
                "Biblioteca.cpp",
                "-o",
                "app"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Entrega 1"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compila main.cpp + Biblioteca.cpp em Entrega 1/app"
        },
        {
            "type": "shell",
            "label": "C/C++: executar Entrega 1",
            "command": "./app",
            "options": {
                "cwd": "${workspaceFolder}/Entrega 1"
            },
            "dependsOn": "C/C++: build Entrega 1",
            "problemMatcher": []
        }
    ],
    "version": "2.0.0"
}