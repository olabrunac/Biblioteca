{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: build active folder",
            "command": "g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "*.cpp",
                "-o",
                "app.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compila todos os .cpp da pasta do arquivo ativo em app"
        },
        {
            "type": "shell",
            "label": "C/C++: executar active folder",
            "command": "./app.exe",
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": "C/C++: build active folder",
            "problemMatcher": []
        }
    ],
    "version": "2.0.0"
}